@page "/"

@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using ChartJs.Blazor.PieChart
@using ChartJs.Blazor.BarChart

@attribute [Authorize]

<PageTitle>Dashboard - Ledgr</PageTitle>

<div class="container-fluid">
    <h1 class="mb-4">Dashboard</h1>

    @if (isLoading)
    {
        <div class="loading-spinner">
            <Spinner Color="Primary" Size="Style.Width.Rem(3)" />
        </div>
    }
    else
    {
        <!-- Stats Cards -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card stats-card balance">
                    <div class="stats-label">Total Balance</div>
                    <div class="stats-value">@summary?.TotalBalance.ToString("C")</div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card stats-card income">
                    <div class="stats-label">Income (This Month)</div>
                    <div class="stats-value">@summary?.TotalIncome.ToString("C")</div>
                </div>
            </div>
            <div="div class="col-md-4">
                <div class="card stats-card expenses">
                    <div class="stats-label">Expenses (This Month)</div>
                    <div class="stats-value">@summary?.TotalExpenses.ToString("C")</div>
                </div>
            </div>
        </div>

        <!-- Charts Row -->
        <div class="row mb-4">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Expenses by Category</h5>
                    </div>
                    <div class="card-body">
                        @if (expenseChartData != null && expenseChartData.Labels.Any())
                        {
                            <Chart Config="pieConfig"></Chart>
                        }
                        else
                        {
                            <p class="text-muted">No expense data available</p>
                        }
                    </div>
                </div>
            </div>
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h5 class="mb-0">Top Spending Categories</h5>
                    </div>
                    <div class="card-body">
                        @if (summary?.TopExpenseCategories.Any() == true)
                        {
                            @foreach (var category in summary.TopExpenseCategories)
                            {
                                <div class="mb-3">
                                    <div class="d-flex justify-content-between mb-1">
                                        <span>
                                            <span class="category-dot" style="background-color: @category.Color"></span>
                                            @category.CategoryName
                                        </span>
                                        <span class="fw-bold">@category.Amount.ToString("C")</span>
                                    </div>
                                    <div class="progress" style="height: 8px;">
                                        <div class="progress-bar" style="width: @category.Percentage%; background-color: @category.Color;"></div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-muted">No expense data available</p>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Transactions -->
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <h5 class="mb-0">Recent Transactions</h5>
                        <a href="transactions" class="btn btn-sm btn-primary">View All</a>
                    </div>
                    <div class="card-body">
                        @if (summary?.RecentTransactions.Any() == true)
                        {
                            <Table Hoverable="true" Responsive="true">
                                <TableHeader>
                                    <TableRow>
                                        <TableHeaderCell>Date</TableHeaderCell>
                                        <TableHeaderCell>Description</TableHeaderCell>
                                        <TableHeaderCell>Category</TableHeaderCell>
                                        <TableHeaderCell>Type</TableHeaderCell>
                                        <TableHeaderCell>Amount</TableHeaderCell>
                                    </TableRow>
                                </TableHeader>
                                <TableBody>
                                    @foreach (var transaction in summary.RecentTransactions)
                                    {
                                        <TableRow>
                                            <TableRowCell>@transaction.Date.ToString("MMM dd, yyyy")</TableRowCell>
                                            <TableRowCell>@transaction.Description</TableRowCell>
                                            <TableRowCell>
                                                <span class="category-dot" style="background-color: @transaction.Category?.Color"></span>
                                                @transaction.Category?.Name
                                            </TableRowCell>
                                            <TableRowCell>
                                                <Badge Color="@(transaction.Type == TransactionType.Income ? Color.Success : Color.Danger)">
                                                    @transaction.Type
                                                </Badge>
                                            </TableRowCell>
                                            <TableRowCell>
                                                <span class="@(transaction.Type == TransactionType.Income ? "transaction-income" : "transaction-expense")">
                                                    @(transaction.Type == TransactionType.Income ? "+" : "-")@transaction.Amount.ToString("C")
                                                </span>
                                            </TableRowCell>
                                        </TableRow>
                                    }
                                </TableBody>
                            </Table>
                        }
                        else
                        {
                            <p class="text-muted text-center">No transactions yet. 
                                <a href="transactions/add">Add your first transaction</a>
                            </p>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Inject] private DashboardService DashboardService { get; set; } = null!;
    [Inject] private IChartService ChartService { get; set; } = null!;
    [Inject] private AuthenticationStateProvider AuthState { get; set; } = null!;

    private bool isLoading = true;
    private DashboardSummary? summary;
    private ChartData? expenseChartData;
    private PieConfig? pieConfig;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

        if (!string.IsNullOrEmpty(userId))
        {
            summary = await DashboardService.GetDashboardSummaryAsync(userId);
            
            // Get expense chart data
            var startOfMonth = new DateTime(DateTime.UtcNow.Year, DateTime.UtcNow.Month, 1);
            var endOfMonth = startOfMonth.AddMonths(1).AddDays(-1);
            expenseChartData = await ChartService.GetExpensesByCategoryAsync(userId, startOfMonth, endOfMonth);
            
            // Setup pie chart
            if (expenseChartData.Labels.Any())
            {
                SetupPieChart();
            }
        }

        isLoading = false;
    }

    private void SetupPieChart()
    {
        pieConfig = new PieConfig
        {
            Options = new PieOptions
            {
                Responsive = true,
                MaintainAspectRatio = false,
                Legend = new Legend
                {
                    Position = LegendPosition.Right
                }
            }
        };

        pieConfig.Data.Labels = expenseChartData!.Labels;
        pieConfig.Data.Datasets.Add(new PieDataset
        {
            Data = expenseChartData.Data.Select(d => (double)d).ToList(),
            BackgroundColor = expenseChartData.Colors,
            BorderWidth = 2,
            HoverBorderWidth = 4
        });
    }
}