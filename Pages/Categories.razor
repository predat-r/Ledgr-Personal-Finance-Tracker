@page "/categories"

@using Microsoft.AspNetCore.Authorization
@using Blazorise

@attribute [Authorize]

<PageTitle>Categories - Ledgr</PageTitle>

<div class="container-fluid">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Categories</h1>
        <Button Color="Color.Primary" Clicked="ShowAddModal">
            <Icon Name="IconName.Add" /> Add Category
        </Button>
    </div>

    <div class="row">
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Income Categories</h5>
                </div>
                <div class="card-body">
                    @foreach (var category in incomeCategories)
                    {
                        <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                            <div>
                                <span class="category-dot" style="background-color: @category.Color"></span>
                                @category.Name
                            </div>
                            <div>
                                <Button Color="Color.Info" Size="Size.Small" Clicked="() => EditCategory(category)">
                                    <Icon Name="IconName.Edit" />
                                </Button>
                                <Button Color="Color.Danger" Size="Size.Small" Clicked="() => ConfirmDelete(category)">
                                    <Icon Name="IconName.Delete" />
                                </Button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header">
                    <h5 class="mb-0">Expense Categories</h5>
                </div>
                <div class="card-body">
                    @foreach (var category in expenseCategories)
                    {
                        <div class="d-flex justify-content-between align-items-center p-2 border-bottom">
                            <div>
                                <span class="category-dot" style="background-color: @category.Color"></span>
                                @category.Name
                            </div>
                            <div>
                                <Button Color="Color.Info" Size="Size.Small" Clicked="() => EditCategory(category)">
                                    <Icon Name="IconName.Edit" />
                                </Button>
                                <Button Color="Color.Danger" Size="Size.Small" Clicked="() => ConfirmDelete(category)">
                                    <Icon Name="IconName.Delete" />
                                </Button>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add/Edit Category Modal -->
<Modal @bind-Visible="showModal">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>@(isEditing ? "Edit Category" : "Add Category")</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <Field>
                <FieldLabel>Name</FieldLabel>
                <TextEdit @bind-Text="categoryName" Placeholder="Category name" />
            </Field>
            <Field>
                <FieldLabel>Type</FieldLabel>
                <Select @bind-SelectedValue="categoryType">
                    <SelectItem Value="CategoryType.Income">Income</SelectItem>
                    <SelectItem Value="CategoryType.Expense">Expense</SelectItem>
                </Select>
            </Field>
            <Field>
                <FieldLabel>Color</FieldLabel>
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var color in colorOptions)
                    {
                        <Button 
                            Color="@(selectedColor == color ? Color.Primary : Color.Secondary)"
                            Clicked="() => selectedColor = color"
                            Style="background-color: @color; border-color: @color; width: 30px; height: 30px; padding: 0;">
                        </Button>
                    }
                </div>
            </Field>
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="CloseModal">Cancel</Button>
            <Button Color="Color.Primary" Clicked="SaveCategory">
                <Icon Name="IconName.Save" /> Save
            </Button>
        </ModalFooter>
    </ModalContent>
</Modal>

<!-- Delete Confirmation Modal -->
<Modal @bind-Visible="showDeleteModal">
    <ModalContent Centered="true">
        <ModalHeader>
            <ModalTitle>Delete Category</ModalTitle>
            <CloseButton />
        </ModalHeader>
        <ModalBody>
            <p>Are you sure you want to delete this category?</p>
            @if (categoryToDelete != null)
            {
                <Alert Color="Color.Warning">
                    <strong>@categoryToDelete.Name</strong> - This action cannot be undone.
                </Alert>
            }
        </ModalBody>
        <ModalFooter>
            <Button Color="Color.Secondary" Clicked="CloseDeleteModal">Cancel</Button>
            <Button Color="Color.Danger" Clicked="DeleteCategory">
                <Icon Name="IconName.Delete" /> Delete
            </Button>
        </ModalFooter>
    </ModalContent>
</Modal>

@code {
    [Inject] private ICategoryService CategoryService { get; set; } = null!;

    private List<Category> categories = new();
    private List<Category> incomeCategories = new();
    private List<Category> expenseCategories = new();

    private bool showModal;
    private bool showDeleteModal;
    private bool isEditing;
    private string categoryName = string.Empty;
    private CategoryType categoryType = CategoryType.Expense;
    private string selectedColor = "#6c757d";
    private int editingCategoryId;
    private Category? categoryToDelete;

    private List<string> colorOptions = new()
    {
        "#28a745", "#17a2b8", "#ffc107", "#dc3545", "#fd7e14", 
        "#e83e8c", "#6f42c1", "#007bff", "#20c997", "#343a40", "#6c757d"
    };

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        categories = await CategoryService.GetAllCategoriesAsync();
        incomeCategories = categories.Where(c => c.Type == CategoryType.Income).ToList();
        expenseCategories = categories.Where(c => c.Type == CategoryType.Expense).ToList();
    }

    private void ShowAddModal()
    {
        isEditing = false;
        categoryName = string.Empty;
        categoryType = CategoryType.Expense;
        selectedColor = "#6c757d";
        showModal = true;
    }

    private void EditCategory(Category category)
    {
        isEditing = true;
        editingCategoryId = category.Id;
        categoryName = category.Name;
        categoryType = category.Type;
        selectedColor = category.Color ?? "#6c757d";
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveCategory()
    {
        if (string.IsNullOrWhiteSpace(categoryName))
            return;

        if (isEditing)
        {
            var category = categories.FirstOrDefault(c => c.Id == editingCategoryId);
            if (category != null)
            {
                category.Name = categoryName;
                category.Type = categoryType;
                category.Color = selectedColor;
                await CategoryService.UpdateCategoryAsync(category);
            }
        }
        else
        {
            var newCategory = new Category
            {
                Name = categoryName,
                Type = categoryType,
                Color = selectedColor
            };
            await CategoryService.CreateCategoryAsync(newCategory);
        }

        await LoadCategories();
        CloseModal();
    }

    private void ConfirmDelete(Category category)
    {
        categoryToDelete = category;
        showDeleteModal = true;
    }

    private void CloseDeleteModal()
    {
        showDeleteModal = false;
        categoryToDelete = null;
    }

    private async Task DeleteCategory()
    {
        if (categoryToDelete != null)
        {
            var hasTransactions = await CategoryService.CategoryHasTransactionsAsync(categoryToDelete.Id);
            if (!hasTransactions)
            {
                await CategoryService.DeleteCategoryAsync(categoryToDelete.Id);
                await LoadCategories();
            }
        }
        CloseDeleteModal();
    }
}